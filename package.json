{
  "name": "a-stock-agent-studio",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev:web": "npm --prefix apps/web run dev -- --host 0.0.0.0",
    "build:web": "npm --prefix apps/web run build",
    "preview:web": "npm --prefix apps/web run preview",
    "dev:api": "apps/api/.venv/Scripts/python -m uvicorn app.main:app --app-dir apps/api --reload --host 0.0.0.0 --port 8000",
    "lint:api": "apps/api/.venv/Scripts/python -m ruff check apps/api",
    "test:api": "apps/api/.venv/Scripts/python -m pytest apps/api/tests"
  }
}
